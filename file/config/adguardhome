
config AdGuardHome 'AdGuardHome'
	option configpath '/etc/AdGuardHome.yaml'
	option workdir '/etc/AdGuardHome'
	option redirect 'redirect'
	option logfile '/tmp/AdGuardHome.log'
	option verbose '0'
	option binpath '/usr/bin/AdGuardHome'
	option enabled '1'
	option core_version 'latest'
	option waitonboot '1'
	option update_url 'https://github.com/AdguardTeam/AdGuardHome/releases/download/${Cloud_Version}/AdGuardHome_linux_${Arch}.tar.gz'
	option hostsmd5 '5504bb04bd01cb0e340aee9e2ae065b2'
	option version 'v0.107.72'
	option binmtime '1772952314'
	option httpport '3000'
	option backupfile 'filters stats.db querylog.json sessions.db'
	option backupwdpath '/etc/AdGuardHome'
	option ucitracktest '1'
	option upprotect '$binpath $configpath $logfile $workdir/data/sessions.db $workdir/data/stats.db $workdir/data/querylog.json $workdir/data/filters'
	list old_redirect 'redirect'
	list old_port '5553'
	list old_enabled '1'

